# Example Hooks V2 configuration
# Copy this file to .aworld/hooks.yaml in your workspace and enable the hooks you need.

version: "v2"

hooks:
  # ====================================
  # Safety hooks
  # ====================================

  # Block dangerous shell commands such as rm -rf /
  - name: "dangerous-command-blocker"
    hook_point: "before_tool_call"
    enabled: true
    command: "./docs/AWorld CLI/Hooks/Examples/dangerous_command_blocker.sh"
    timeout: 2000

  # Sanitize path-like arguments before execution
  - name: "path-sanitizer"
    hook_point: "before_tool_call"
    enabled: true
    command: "./docs/AWorld CLI/Hooks/Examples/path_sanitizer.sh"
    timeout: 2000

  # Filter sensitive values from tool output
  - name: "output-filter"
    hook_point: "after_tool_call"
    enabled: true
    command: "./docs/AWorld CLI/Hooks/Examples/output_filter.sh"
    timeout: 3000

  # ====================================
  # Audit hooks
  # ====================================

  # Record all tool calls
  - name: "audit-logger"
    hook_point: "after_tool_call"
    enabled: true
    command: "./docs/AWorld CLI/Hooks/Examples/audit_logger.sh"
    timeout: 5000

  # ====================================
  # Rate-limiting hooks
  # ====================================

  # Limit tool calls to 20 per minute
  - name: "rate-limiter"
    hook_point: "before_tool_call"
    enabled: false
    command: "./docs/AWorld CLI/Hooks/Examples/rate_limiter.sh"
    timeout: 2000
    env:
      MAX_CALLS_PER_MINUTE: "20"
      WINDOW_SECONDS: "60"

  # ====================================
  # Notification hooks
  # ====================================

  # Notify when a session starts
  - name: "session-started-notification"
    hook_point: "session_started"
    enabled: false
    command: "./docs/AWorld CLI/Hooks/Examples/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # Notify when a session finishes
  - name: "session-finished-notification"
    hook_point: "session_finished"
    enabled: false
    command: "./docs/AWorld CLI/Hooks/Examples/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # Notify when a session fails
  - name: "session-failed-notification"
    hook_point: "session_failed"
    enabled: false
    command: "./docs/AWorld CLI/Hooks/Examples/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # ====================================
  # Python callback hooks
  # ====================================

  # Custom Python hook example
  # - name: "python-audit-hook"
  #   hook_point: "after_tool_call"
  #   callback: "mypackage.hooks:audit_tool_call"
  #   enabled: true

# ====================================
# Notes
# ====================================

# hook_point values:
#   - session_started
#   - session_finished
#   - session_failed
#   - user_input_received
#   - before_tool_call
#   - after_tool_call
#   - tool_call_failed

# enabled: whether the hook is active

# command: shell command path relative to the workspace root

# callback: Python callback path in module:function form

# timeout: execution timeout in milliseconds

# env: extra environment variables passed to the hook
