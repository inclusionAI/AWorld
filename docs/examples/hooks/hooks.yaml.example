# AWorld Hooks V2 配置文件示例
# 将此文件复制到项目根目录的 .aworld/hooks.yaml 并根据需要启用/配置 hooks

version: "v2"

hooks:
  # ====================================
  # 安全防护 Hooks
  # ====================================

  # 危险命令拦截：阻止执行 rm -rf / 等危险命令
  - name: "dangerous-command-blocker"
    hook_point: "before_tool_call"
    enabled: true
    command: "./docs/examples/hooks/dangerous_command_blocker.sh"
    timeout: 2000

  # 路径清理：防止路径遍历攻击
  - name: "path-sanitizer"
    hook_point: "before_tool_call"
    enabled: true
    command: "./docs/examples/hooks/path_sanitizer.sh"
    timeout: 2000

  # 输出过滤：过滤敏感信息（API keys, passwords 等）
  - name: "output-filter"
    hook_point: "after_tool_call"
    enabled: true
    command: "./docs/examples/hooks/output_filter.sh"
    timeout: 3000

  # ====================================
  # 审计日志 Hooks
  # ====================================

  # 审计日志：记录所有工具调用
  - name: "audit-logger"
    hook_point: "after_tool_call"
    enabled: true
    command: "./docs/examples/hooks/audit_logger.sh"
    timeout: 5000

  # ====================================
  # 速率限制 Hooks
  # ====================================

  # 速率限制：限制每分钟最多 20 次工具调用
  - name: "rate-limiter"
    hook_point: "before_tool_call"
    enabled: false  # 默认禁用，按需启用
    command: "./docs/examples/hooks/rate_limiter.sh"
    timeout: 2000
    env:
      MAX_CALLS_PER_MINUTE: "20"
      WINDOW_SECONDS: "60"

  # ====================================
  # 通知 Hooks
  # ====================================

  # 会话开始通知
  - name: "session-started-notification"
    hook_point: "session_started"
    enabled: false  # 默认禁用，按需启用
    command: "./docs/examples/hooks/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"  # 可选：slack, webhook, none
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # 会话完成通知
  - name: "session-finished-notification"
    hook_point: "session_finished"
    enabled: false
    command: "./docs/examples/hooks/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # 会话失败通知
  - name: "session-failed-notification"
    hook_point: "session_failed"
    enabled: false
    command: "./docs/examples/hooks/session_notification.sh"
    timeout: 5000
    env:
      AWORLD_NOTIFICATION_TYPE: "slack"
      AWORLD_SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

  # ====================================
  # Python Callback Hooks（高级用法）
  # ====================================

  # 自定义 Python hook 示例
  # - name: "python-audit-hook"
  #   hook_point: "after_tool_call"
  #   callback: "mypackage.hooks:audit_tool_call"
  #   enabled: true

# ====================================
# 配置说明
# ====================================

# hook_point: Hook 触发点，可选值：
#   - session_started: 会话开始
#   - session_finished: 会话完成
#   - session_failed: 会话失败
#   - user_input_received: 用户输入接收
#   - before_tool_call: 工具调用前
#   - after_tool_call: 工具调用后
#   - tool_call_failed: 工具调用失败

# enabled: 是否启用此 hook（true/false）

# command: Shell 命令路径（相对于项目根目录）

# callback: Python 函数路径（格式：module:function）

# timeout: Hook 执行超时时间（毫秒），默认 600000（10分钟）

# env: 传递给 hook 的自定义环境变量
